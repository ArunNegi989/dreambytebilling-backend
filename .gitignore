# -----------------------------------
# 🔒 Environment Variables (DO NOT COMMIT)
# -----------------------------------
.env
.env.*
!*.example

# JWT / Credentials / Keys
*.key
*.pem

# -----------------------------------
# 📦 Dependencies
# -----------------------------------
node_modules/
jspm_packages/
bower_components/

# -----------------------------------
# 🧱 Build Output (Frontend & Backend)
# -----------------------------------
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist
.temp
.cache
.parcel-cache

# -----------------------------------
# 📝 Logs & Debug
# -----------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# -----------------------------------
# 🧪 Coverage
# -----------------------------------
coverage/
*.lcov
.nyc_output

# -----------------------------------
# 📁 Runtime / Process Files
# -----------------------------------
pids
*.pid
*.seed
*.pid.lock

# -----------------------------------
# 🛠️ Build Artifacts / Addons
# -----------------------------------
build/Release
lib-cov

# -----------------------------------
# 🧩 TypeScript
# -----------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------
# 🧰 Tools & Caches
# -----------------------------------
.grunt
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.webpack/
.fusebox/
.serverless/

# -----------------------------------
# 🧬 Testing / REPL
# -----------------------------------
.node_repl_history

# -----------------------------------
# 📦 Package Output
# -----------------------------------
*.tgz

# -----------------------------------
# 🔐 Yarn 2
# -----------------------------------
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------
# 🗂️ IDE / Editor
# -----------------------------------
.vscode/
.idea/
*.swp

# -----------------------------------
# 📸 OS / System Files
# -----------------------------------
.DS_Store
Thumbs.db

# -----------------------------------
# 📁 Public Folder (if auto-generated)
# -----------------------------------
public/

# -----------------------------------
